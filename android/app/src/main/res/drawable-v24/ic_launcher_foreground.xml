<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- pine sprig (rosin = pine resin) -->
    <path
        android:pathData="M54,11 L54,27 M54,15 L46,9 M54,15 L62,9 M54,20 L47,16 M54,20 L61,16"
        android:strokeColor="#A9BE66"
        android:strokeWidth="2.4"
        android:strokeLineCap="round" />

    <!-- molten rosin / flux droplet -->
    <path android:pathData="M54,26 C64,46 80,56 80,66 a26,26 0 1 1 -52,0 C28,56 44,46 54,26 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="26"
                android:endX="54" android:endY="92">
                <item android:offset="0" android:color="#FFFFE0A3"/>
                <item android:offset="0.42" android:color="#FFFFAB4D"/>
                <item android:offset="0.78" android:color="#FFF5731F"/>
                <item android:offset="1" android:color="#FFD6431A"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- specular gloss -->
    <path
        android:pathData="M45,62 a6,9 0 1 0 12,0 a6,9 0 1 0 -12,0 Z"
        android:fillColor="#73FFFFFF" />
    <path
        android:pathData="M64,80 a3.2,3.2 0 1 0 6.4,0 a3.2,3.2 0 1 0 -6.4,0 Z"
        android:fillColor="#40FFFFFF" />
</vector>
