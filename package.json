{
  "name": "pinecil-companion",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Material You companion app for the Pinecil V2 soldering iron over Bluetooth LE",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "cap:sync": "npm run build && cap sync",
    "android": "npm run build && cap sync android && cap open android",
    "android:run": "npm run build && cap run android",
    "desktop": "npm run build && electron electron/main.cjs"
  },
  "dependencies": {
    "@capacitor-community/bluetooth-le": "^6.0.1",
    "@capacitor/android": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/splash-screen": "^6.0.2",
    "@capacitor/status-bar": "^6.0.1",
    "@material/material-color-utilities": "^0.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.1.2",
    "electron": "^33.2.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/web-bluetooth": "^0.0.20",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-pwa": "^0.21.1"
  }
}
